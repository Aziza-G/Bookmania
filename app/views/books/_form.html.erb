<%= form_with(model: book) do |form| %>
  <% if book.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(book.errors.count, "error") %> prohibited this book from being saved:</h2>

      <ul>
        <% book.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

    <div>
      <%= form.label :author, style: "display: block"%>
      <%= form.text_field :author%>
    </div>

  <div class="mb-4">
    <%= form.label :genre, class: "block font-semibold mb-2" %>
    <%= form.select :genre, 
      Book::GENRES, 
      { prompt: "Select a genre"}, class: "w-full border rounded-lg p-2" %>
  </div>

    <div>
      <%= form.label :cost, style: "display: block"%>
      <%= form.number_field :cost%>
    </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.textarea :description %>
  </div>

  <div>
    <%= form.label :notes, style: "display: block" %>
    <%= form.textarea :notes %>
  </div>

<div class="mb-4>
  <%= form.label :book_file, "Upload Book File", class: "block font-semibold mb-2"%>
  <%= form.file_field :book_file, class: "border p-2 rounded w-full"%>
</div>
  <div>
    <%= form.submit %>
  </div>
<% end %>
