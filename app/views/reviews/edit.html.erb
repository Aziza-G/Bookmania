<h1 class="text-3xl font-bold mb-6">Edit Review</h1>

<%= form_with(model: [@book, @review]) do |form| %>

  <!-- Star Rating -->
  <div class="mb-4">
    <%= form.label :rating, "Rating", class: "block font-semibold mb-2" %>

    <div class="flex flex-row-reverse justify-end">
      <% (1..5).each do |star| %>
        <%= form.radio_button :rating, star,
              id: "edit_review_rating_#{star}",
              class: "peer hidden" %>

        <%= form.label "edit_review_rating_#{star}", "★",
              class: "text-4xl cursor-pointer select-none
                      text-gray-300
                      hover:text-yellow-400
                      peer-checked:text-yellow-400" %>
      <% end %>
    </div>
  </div>

  <!-- Review Content -->
  <div class="mb-4">
    <%= form.label :content, "Review", class: "block font-semibold mb-2" %>
    <%= form.text_area :content,
          rows: 5,
          class: "w-full border rounded-lg p-3" %>
  </div>

  <!-- Buttons -->
  <div class="flex gap-3">
    <%= form.submit "Update Review",
          class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>

    <%= link_to "Cancel",
          @book,
          class: "bg-gray-300 text-gray-800 px-4 py-2 rounded-lg hover:bg-gray-400" %>
  </div>

<% end %>